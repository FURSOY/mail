{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FURSOY Mail",
  "version": "1.7.0",
  "identifier": "com.fsoye.mailapp",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "FURSOY Mail",
        "width": 1100,
        "height": 700,
        "minWidth": 600,
        "minHeight": 600,
        "visible": false,
        "decorations": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' https: http: data: blob:; connect-src 'self' https://gmail.googleapis.com https://oauth2.googleapis.com https://accounts.google.com https://www.googleapis.com; frame-src 'self' blob: data:"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/FURSOY/mail/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDUwRDc1MjFCMjA1OEYwOEUKUldTTzhGZ2dHMUxYVUc3OFFFOWVpRnduQlpaRFV2RWh3ZURpNHJtSFp3M21QbnM4NnNBa296TkcK"
    }
  }
}
